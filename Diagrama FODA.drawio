        <mxCell id="KG-HDRhO_zHpLkIWIPAG-11" value="&lt;h1&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Fortalezas:&lt;/font&gt;&lt;/h1&gt;&lt;div&gt;- Interfaz de usuario que se adapta a todos&lt;/div&gt;&lt;div&gt;- Sistema amplio que cuenta con muchas opciones&lt;/div&gt;&lt;div&gt;- Sistema seguro&lt;/div&gt;&lt;div&gt;- Sistema activo 24/7&lt;/div&gt;&lt;div&gt;- Filtro para comentarios inadecuados&lt;/div&gt;&lt;div&gt;- Sistema con monitoreo para informacion falsa&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="270" y="208" width="320" height="192" as="geometry" />
